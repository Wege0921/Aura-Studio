{
  "framework": "create-react-app",
  "buildCommand": "npm run vercel-build",
  "installCommand": "npm install --legacy-peer-deps && cd backend && npm install --legacy-peer-deps",
  "outputDirectory": "build",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
